<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>com.example.speech-tap</string>
	<key>CFBundleName</key>
	<string>SpeechTap</string>
	<key>CFBundleDisplayName</key>
	<string>SpeechTap</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>26.0</string>
	<!-- メニューバー常駐（Dock 非表示）。NSApplication の accessory policy と併用する。 -->
	<key>LSUIElement</key>
	<true/>
	<!-- 固定要件: 音声キャプチャ権限のみ。Core Audio Process Tap が対象アプリ出力をタップするために要求する。
	     画面収録権限・マイク権限は要求しない。 -->
	<key>NSAudioCaptureUsageDescription</key>
	<string>SpeechTap は選択したアプリの音声を文字起こしするために、そのアプリの音声出力をキャプチャします。マイクや画面は記録しません。</string>
</dict>
</plist>
